root = true

[*.{kt,kts}]
# Align ktlint with Android Studio's formatter so "Reformat Code" (Cmd+Alt+L)
# keeps CI green. Options: ktlint_official | intellij_idea | android_studio.
ktlint_code_style = ktlint_official
# Jetpack Compose @Composable functions are intentionally PascalCase.
ktlint_function_naming_ignore_when_annotated_with = Composable
